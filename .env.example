PORT=10000

# Where callback requests should be sent
CALLBACK_TO_EMAIL=kua.center@gmail.com
# Backend-only origin used when running server.js on Render
FORMSUBMIT_ORIGIN=https://kuac-center.onrender.com

# Optional SMTP fallback settings for Nodemailer
# A free Gmail account works here if you use an app password.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password

# Optional: override the "from" address used in outgoing mail
CALLBACK_FROM_EMAIL=no-reply@example.com
